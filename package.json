{
  "name": "vestos-calculator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Halachic Vestos Calculator - desktop app for calculating separation days",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build",
    "extension:dev": "vite --config extension/vite.config.ts",
    "extension:check": "tsc -p extension/tsconfig.json --noEmit",
    "extension:build": "npm run extension:check && vite build --config extension/vite.config.ts",
    "extension:package": "npm run extension:build && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-extension.ps1",
    "store:assets": "python scripts/generate-store-assets.py",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hebcal/core": "^5.5.0",
    "i18next": "^23.11.0",
    "idb": "^8.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^14.1.0",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@tauri-apps/cli": "^2.11.2",
    "@types/chrome": "^0.1.36",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.20.0",
    "vitest": "^1.6.0"
  }
}
