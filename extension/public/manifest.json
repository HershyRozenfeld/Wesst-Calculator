{
  "manifest_version": 3,
  "name": "מחשבון ווסתות",
  "short_name": "ווסתות",
  "version": "0.1.1",
  "description": "חישוב ימי פרישה, גיבוי פרטי ב-Google Drive ותזכורות מותאמות אישית",
  "minimum_chrome_version": "111",
  "permissions": ["identity", "identity.email", "storage", "alarms", "notifications"],
  "host_permissions": ["https://www.googleapis.com/*"],
  "oauth2": {
    "client_id": "330622758347-ske4ru2mu706o2u0kr45h31rcjoamc52.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/drive.appdata"]
  },
  "background": { "service_worker": "service-worker.js", "type": "module" },
  "action": {
    "default_title": "מחשבון ווסתות",
    "default_popup": "popup.html",
    "default_icon": { "16": "icons/icon-16.png", "32": "icons/icon-32.png" }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
